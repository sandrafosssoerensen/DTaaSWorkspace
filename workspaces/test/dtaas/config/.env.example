# OAuth2/OIDC Configuration for Traefik Forward Auth
# Copy this file to .env and fill in your actual values

# ==============================================================================
# KEYCLOAK CONFIGURATION (Default for compose.traefik.secure.yml)
# ==============================================================================

# Keycloak Admin Credentials (for initial setup only)
# Set a strong, unique admin password before running in any environment
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme

# Keycloak Realm Configuration
# The realm name where your application and users are configured
KEYCLOAK_REALM=dtaas

# Keycloak OIDC Client Configuration
# Create a client in your Keycloak realm with:
# - Client ID: dtaas-workspace
# - Access Type: confidential
# - Valid Redirect URIs: http://localhost/_oauth/* (or your domain)
# - Web Origins: http://localhost (or your domain)
KEYCLOAK_CLIENT_ID=dtaas-workspace
KEYCLOAK_CLIENT_SECRET=your_keycloak_client_secret_here

# Keycloak Issuer URL
# traefik-forward-auth fetches the OIDC discovery doc directly from the Keycloak
# container over HTTP to avoid TLS cert issues. Token 'iss' claims still contain
# the public HTTPS URL received from Traefik, which Keycloak reports in the
# discovery doc and which traefik-forward-auth uses for token validation.
# For external Keycloak, use the full URL (e.g., https://keycloak.example.com/auth/realms/dtaas)
# Prefer external keycloak URL for better compliance with traefik and traefik forward-auth setup.
# Note: Keycloak 26.x is configured with legacy /auth path for compatibility
# Valid KEYCLOAK_ISSUER_URL formats
# Localhost (used by compose.traefik.secure.yml): http://localhost/auth/realms/{REALM_NAME}
# Localhost with self-signed certificates (used by compose.traefik.secure.tls.yml): https://localhost/auth/realms/{REALM_NAME}
# External (used by compose.traefik.secure.tls.yml): https://foo.com/auth/realms/{REALM_NAME}
KEYCLOAK_ISSUER_URL=http://localhost/auth/realms/dtaas

# ==============================================================================
# KEYCLOAK CONFIGURATOR SCRIPT
# ==============================================================================
# Variables used by workspaces/test/dtaas/keycloak/configure_keycloak_rest.py
# to set up protocol mappers via the Keycloak Admin REST API.
# These are not used by the compose services themselves.

# Base origin of Keycloak, without the context path
# Examples: http://localhost, https://keycloak.example.com
KEYCLOAK_BASE_URL=http://localhost

# Context path Keycloak is mounted at (e.g. /auth or /)
KEYCLOAK_CONTEXT_PATH=/auth

# Optional: base URL for the profile claim populated on each user.
# Set to override the default (which falls back to KEYCLOAK_BASE_URL).
# The script sets profile=<KEYCLOAK_PROFILE_BASE_URL>/<username> for every user.
# KEYCLOAK_PROFILE_BASE_URL=https://your-domain.com

# Shared scope mode: when set to true, mappers are placed on a shared client
# scope instead of directly on the client. Recommended for multi-client setups.
# When false (default), mappers are placed directly on the client.
KEYCLOAK_USE_SHARED_SCOPE=false
KEYCLOAK_SHARED_SCOPE_NAME=your-shared-scope-name

# Optional: populate the profile attribute for specific users only.
# JSON array of usernames. If unset, all users in the realm are updated.
# KEYCLOAK_USER_PROFILES=["user1", "user2"]

# Alternative admin auth: service-account client credentials instead of
# username/password. Both must be set together to take effect.
# KEYCLOAK_ADMIN_CLIENT_ID=your_admin_client_id
# KEYCLOAK_ADMIN_CLIENT_SECRET=your_admin_client_secret
# ==============================================================================
# Uncomment and configure these if you want to use GitLab instead of Keycloak
# Remember to also update the traefik-forward-auth environment variables in the compose file

# GitLab OAuth Application Configuration
# Create an OAuth application in your GitLab instance at:
# Settings -> Applications (for personal) or
# Admin Area -> Applications (for instance-wide)

# Your GitLab instance URL (without trailing slash)
# Example: https://gitlab.com or https://gitlab.example.com
# OAUTH_URL=https://gitlab.com

# OAuth Application Client ID
# Obtained when creating the OAuth application in GitLab
# OAUTH_CLIENT_ID=your_gitlab_client_id_here

# OAuth Application Client Secret
# Obtained when creating the OAuth application in GitLab
# OAUTH_CLIENT_SECRET=your_gitlab_client_secret_here

# ==============================================================================
# SHARED CONFIGURATION
# ==============================================================================

# Secret key for encrypting OAuth session data
# Generate a random string (at least 16 characters)
# Example: openssl rand -base64 32
OAUTH_SECRET=your_random_secret_key_here

# Server Configuration
# Replace with your domain name (foo.com or localhost)
SERVER_DNS=localhost

# Redirect URL Configuration
# When creating the OAuth/OIDC application, set the redirect URL to:
# http://localhost/_oauth (for local development)
# or https://your-domain.com/_oauth (for production)

# Username Configuration
# These usernames will be used as path prefixes for user workspaces
# Example: http://localhost/user1, http://localhost/user2
USERNAME1=user1
USERNAME2=user2

# Docker Host Hostname for OIDC Discovery
# traefik-forward-auth needs to reach Traefik/Keycloak from inside its container.
# extra_hosts maps this hostname to the Docker host IP (via host-gateway).
# This must match the hostname in KEYCLOAK_ISSUER_URL.
# - Use "localhost" on Ubuntu OS (overrides 127.0.0.1 → host IP)
# - Use "host.docker.internal" on Windows OS and Mac OS
DOCKER_HOST_HOSTNAME=localhost
