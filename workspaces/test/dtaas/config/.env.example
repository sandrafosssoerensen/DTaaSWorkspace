# DTaaS Configuration
# Copy this file to .env and fill in your actual values.
#
# Variable usage by compose file:
#   compose.traefik.secure.yml     — HTTP, traefik-forward-auth + Keycloak
#   compose.traefik.secure.tls.yml — HTTPS, Oathkeeper + login-relay + Keycloak

# ==============================================================================
# KEYCLOAK CONFIGURATION
# Required by: compose.traefik.secure.yml, compose.traefik.secure.tls.yml
# ==============================================================================

# Keycloak Admin Credentials (for initial setup only)
# Set a strong, unique admin password before running in any environment
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme

# Keycloak Realm Configuration
# The realm name where your application and users are configured
KEYCLOAK_REALM=dtaas

# Keycloak OIDC client
# Create a confidential client in your Keycloak realm.
# See KEYCLOAK_SETUP.md for full instructions.
KEYCLOAK_CLIENT_ID=dtaas-workspace
KEYCLOAK_CLIENT_SECRET=your_keycloak_client_secret_here

# ==============================================================================
# KEYCLOAK ISSUER URL
# Required by: compose.traefik.secure.yml (traefik-forward-auth).
# Safe to leave set when using compose.traefik.secure.tls.yml — that compose
# overrides this value internally using SERVER_DNS and KEYCLOAK_REALM.
# ==============================================================================

# For compose.traefik.secure.yml (HTTP, traefik-forward-auth):
#   http://localhost/auth/realms/dtaas        (local)
#   http://keycloak:8080/auth/realms/dtaas    (internal container URL)
KEYCLOAK_ISSUER_URL=http://localhost/auth/realms/dtaas

# ==============================================================================
# LEGACY GITLAB OAUTH CONFIGURATION
# Optional — only for compose.traefik.secure.yml with GitLab instead of Keycloak
# ==============================================================================

# OAUTH_URL=https://gitlab.com
# OAUTH_CLIENT_ID=your_gitlab_client_id_here
# OAUTH_CLIENT_SECRET=your_gitlab_client_secret_here

# ==============================================================================
# SHARED CONFIGURATION
# ==============================================================================

# Server domain name
# Use "localhost" for local testing or your public domain for remote deployments
SERVER_DNS=localhost

# Username configuration
# Used as path prefixes for user workspaces
# Example: https://yourdomain.com/user1, https://yourdomain.com/user2
USERNAME1=user1
USERNAME2=user2

# ==============================================================================
# TRAEFIK FORWARD AUTH CONFIGURATION
# Required by: compose.traefik.secure.yml only
# Not needed for compose.traefik.secure.tls.yml
# ==============================================================================

# Secret key for encrypting OAuth session cookies
# Generate with: openssl rand -base64 32
OAUTH_SECRET=your_random_secret_key_here

# Docker host hostname for OIDC discovery
# traefik-forward-auth needs to reach Keycloak from inside its container.
# - Use "localhost" on Linux/Ubuntu
# - Use "host.docker.internal" on Windows or macOS
DOCKER_HOST_HOSTNAME=localhost
