# OAuth2/OIDC Configuration for Traefik Forward Auth
# Copy this file to .env and fill in your actual values

# ==============================================================================
# KEYCLOAK CONFIGURATION (Default for compose.traefik.secure.yml)
# ==============================================================================

# Keycloak Admin Credentials (for initial setup only)
# Set a strong, unique admin password before running in any environment
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme

# Keycloak Realm Configuration
# The realm name where your application and users are configured
KEYCLOAK_REALM=dtaas

# Keycloak OIDC Client ID
# Create a public client in your Keycloak realm with:
# - Client ID: dtaas-workspace
# - Access Type: public (PKCE; no client secret required)
# - Valid Redirect URIs: http://localhost/Library (or your domain)
# - Web Origins: http://localhost (or your domain)
# - Advanced > Proof Key for Code Exchange: S256
KEYCLOAK_CLIENT_ID=dtaas-workspace

# Keycloak Issuer URL
# This must match EXACTLY the 'iss' claim in JWTs issued by Keycloak.
# Keycloak sets 'iss' to its public KC_HOSTNAME value.
# For HTTP mode  (compose.traefik.secure.yml):     http://<SERVER_DNS>/auth/realms/<realm>
# For HTTPS mode (compose.traefik.secure.tls.yml): https://<SERVER_DNS>/auth/realms/<realm>
# The oathkeeper service derives this automatically from SERVER_DNS and KEYCLOAK_REALM
# in the compose file; this variable is kept here for reference and documentation.
# Example (HTTP):  http://localhost/auth/realms/dtaas
# Example (HTTPS): https://foo.com/auth/realms/dtaas
KEYCLOAK_ISSUER_URL=http://localhost/auth/realms/dtaas

# Keycloak JWKS endpoint for Oathkeeper JWT signature verification.
# For embedded Keycloak: leave unset (defaults to internal container URL).
# For external/HTTPS Keycloak: set to the public HTTPS endpoint.
# Example (HTTPS): https://foo.com/auth/realms/dtaas/protocol/openid-connect/certs
# KEYCLOAK_JWKS_URL=https://foo.com/auth/realms/dtaas/protocol/openid-connect/certs

# ==============================================================================
# KEYCLOAK CONFIGURATOR SCRIPT
# ==============================================================================
# Variables used by workspaces/test/dtaas/keycloak/configure_keycloak_rest.py
# to set up protocol mappers via the Keycloak Admin REST API.
# These are not used by the compose services themselves.

# Base origin of Keycloak, without the context path
# Examples: http://localhost, https://keycloak.example.com
KEYCLOAK_BASE_URL=http://localhost

# Context path Keycloak is mounted at (e.g. /auth or /)
KEYCLOAK_CONTEXT_PATH=/auth

# Optional: base URL for the profile claim populated on each user.
# Set to override the default (which falls back to KEYCLOAK_BASE_URL).
# The script sets profile=<KEYCLOAK_PROFILE_BASE_URL>/<username> for every user.
# KEYCLOAK_PROFILE_BASE_URL=https://your-domain.com

# Shared scope mode: when set to true, mappers are placed on a shared client
# scope instead of directly on the client. Recommended for multi-client setups.
# When false (default), mappers are placed directly on the client.
KEYCLOAK_USE_SHARED_SCOPE=true
KEYCLOAK_SHARED_SCOPE_NAME=your-shared-scope-name

# Client auth settings managed by configure_keycloak_rest.py
# Keep this as a public PKCE client for browser-based DTaaS login.
KEYCLOAK_PUBLIC_CLIENT=true
KEYCLOAK_STANDARD_FLOW_ENABLED=true
KEYCLOAK_PKCE_METHOD=S256

# Comma-separated values used to set client redirectUris/webOrigins in Keycloak.
KEYCLOAK_REDIRECT_URIS=https://foo.com/library,https://foo.com/*
KEYCLOAK_WEB_ORIGINS=https://foo.com

# Optional post-logout redirect URIs for the client (comma-separated).
# KEYCLOAK_POST_LOGOUT_REDIRECT_URIS=https://foo.com/*

# Scope assignment enforcement for the target client (comma-separated names).
# When set, the script enforces these lists exactly by adding missing scopes and
# unassigning scopes that are not listed.
# KEYCLOAK_DEFAULT_CLIENT_SCOPES=web-origins,acr,profile,roles,basic,email,dtaas-shared
# KEYCLOAK_OPTIONAL_CLIENT_SCOPES=address,phone,read_user,read_repository,offline_access,organization,microprofile-jwt,api

# Optional: populate the profile attribute for specific users only.
# JSON array of usernames. If unset, all users in the realm are updated.
# KEYCLOAK_USER_PROFILES=["user1", "user2"]

# Automated user provisioning: JSON array of {username, password, role} objects.
# Role must be one of: dtaas-admin, dtaas-user, dtaas-viewer
# If unset, no users are created automatically.
# KEYCLOAK_USERS=[{"username":"user1","password":"changeme","role":"dtaas-user","email":"user1@example.com","firstName":"User","lastName":"One"},{"username":"admin","password":"changeme","role":"dtaas-admin","email":"admin@example.com","firstName":"Admin","lastName":"User"}]

# Alternative admin auth: service-account client credentials instead of
# username/password. Both must be set together to take effect.
# KEYCLOAK_ADMIN_CLIENT_ID=your_admin_client_id
# KEYCLOAK_ADMIN_CLIENT_SECRET=your_admin_client_secret
# ==============================================================================
# SHARED CONFIGURATION
# ==============================================================================

# Secret key for encrypting OAuth session data
# Example: openssl rand -base64 32
OAUTH_SECRET=your_random_secret_here

# Server Configuration
# Replace with your domain name (foo.com or localhost)
SERVER_DNS=foo.com

# Username Configuration
# These usernames will be used as path prefixes for user workspaces
# Example: http://localhost/user1, http://localhost/user2
# Each user must exist in Keycloak with a matching 'preferred_username' attribute.
USERNAME1=user1
USERNAME2=user2
USERNAME_ADMIN=sandra
